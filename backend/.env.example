# ── backend 設定：複製成 .env 再填 ──  cp .env.example .env

# db_api 位址（docker 內用服務名；本機非 docker 開發用 http://localhost:9000）
DB_API_URL=http://db_api:9000

# ── LLM（OpenAI 相容端點）──
LLM_PROVIDER=openai
LLM_BASE_URL=https://devops.avc.co:28003/LLM_api/v1
LLM_MODEL=請填入模型名稱          # 用 /v1/models 查得到
LLM_API_KEY=請填入金鑰            # 端點不需金鑰可留空

# 內部自簽憑證（擇一）
# LLM_CA_BUNDLE=/certs/company-ca.pem
# LLM_VERIFY_SSL=false

# ── Embedding（長期記憶語意召回；預設沿用 LLM_BASE_URL）──
EMBED_MODEL=Qwen3-embedding
# EMBED_BASE_URL=https://devops.avc.co:28003/LLM_api/v1

# ── 公司 RAG 知識庫（knowledge_search skill）──
RAG_BASE_URL=http://172.16.174.116:8001
RAG_TOPK=5
# RAG_VERIFY_SSL=false
# RAG_FILTER=[{"allowDirect":"Y","compCode":"AVC","depCode":"IT","docType":"","empID":"","metadataIds":""}]

# ── 模型分級（路由層用；未設則回退到上面的 LLM_*）──
# 每級各自的端點/模型/金鑰，例如：
# LOCAL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL=qwen2.5
# CLOUD_MODEL=gpt-4o
# MID_MODEL=gpt-4o-mini
# CHEAP_MODEL=gpt-4o-mini

# ── 視覺（圖片）模型白名單：逗號分隔，只有這些模型會被用來吃圖 ──
# 未設時自動用路由表推導（OCR 的 primary + 圖面理解的 primary + baseline）。
# ⚠ 這裡列的模型必須在你 gateway 上真的支援 vision，否則呼叫失敗會退 fallback。
# VISION_MODELS=Qwen3-VL,Grok-4.3
