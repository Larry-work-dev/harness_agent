# ── backend 設定：複製成 .env 再填 ──  cp .env.example .env

# db_api 位址（docker 內用服務名；本機非 docker 開發用 http://localhost:9000）
DB_API_URL=http://xxx.xxx.xxx.xxx:xxxx

# ── LLM（OpenAI compatible）──
LLM_PROVIDER=openai
LLM_BASE_URL=https://xxx.xxx.xxx.xxx:xxxx/LLM_api/v1
LLM_MODEL=Input your LLM model name here  # 用 /v1/models 查得到
LLM_API_KEY=Input your LLM API key here  # 端點不需金鑰可留空

# 內部自簽憑證（擇一）
# LLM_CA_BUNDLE=/certs/company-ca.pem
# LLM_VERIFY_SSL=false

# ── Embedding（長期記憶語意召回；預設沿用 LLM_BASE_URL）──
EMBED_MODEL=Input your embedding model name here  # 用 /v1/models 查得到
# EMBED_BASE_URL=https://xxx.xxx.xxx.xxx:28003/LLM_api/v1

# ── RAG 知識庫（knowledge_search skill）──
RAG_BASE_URL=http://xxx.xxx.xxx.xxx:xxxx
RAG_TOPK=5
# RAG_VERIFY_SSL=false
# RAG_FILTER=[{"allowDirect":"Y","compCode":"AVC","depCode":"IT","docType":"","empID":"","metadataIds":""}]
